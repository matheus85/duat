{
    "name": "matheus85/duat",
    "description": "Unified resilience patterns for modern PHP: retry, circuit breaker, timeout, bulkhead and fallback, with rate limiting on the roadmap. Zero required dependencies.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "resilience",
        "retry",
        "circuit-breaker",
        "rate-limiter",
        "bulkhead",
        "timeout",
        "fallback",
        "backoff"
    ],
    "authors": [
        {
            "name": "Matheus Marques"
        }
    ],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5 || ^12.0",
        "predis/predis": "^3.5",
        "psr/event-dispatcher": "^1.0",
        "psr/simple-cache": "^3.0"
    },
    "suggest": {
        "psr/simple-cache": "To use any PSR-16 cache as shared state store",
        "psr/event-dispatcher": "To receive resilience events (circuit opened, retry attempted...)",
        "ext-redis": "Recommended production state store with atomic operations",
        "predis/predis": "Pure PHP alternative to ext-redis, also supported by RedisStore"
    },
    "autoload": {
        "psr-4": {
            "Duat\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Duat\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:integration": "phpunit --testsuite integration",
        "test:coverage": [
            "@putenv XDEBUG_MODE=coverage",
            "phpunit --coverage-html coverage --coverage-text"
        ],
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix"
    }
}
